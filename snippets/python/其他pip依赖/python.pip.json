  "pip|uv requests 网络请求库": {
    "prefix": ["pip requests", "uv requests"],
    "body": [
      "ECHO.",
      "ECHO * requests 网络请求库 *",
      "pip install \"requests\" --upgrade -i https://mirrors.aliyun.com/pypi/simple/",
      "uv add \"requests\" --upgrade --index https://mirrors.aliyun.com/pypi/simple/",
      ""
    ],
    "description": ["requests 网络请求库"]
  },
