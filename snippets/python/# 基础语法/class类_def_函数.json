{
  "创建 class 对象": {
    "prefix": ["new class -class", "class new -class"],
    "body": [
      "class ${1:NewObject}(${2:}):",
      "    # * class default args(类变量) | signal(信号)",
      "    # 调用方法: [className].[argsName] = [value] | self.[argsName] = [value]",
      "    def __init__(self) -> None:",
      "        # * ${3:_summary_}",
      "        ...",
      "        return",
      "",
      "    ...",
      "    return"
    ],
    "description": ["创建 class 对象"]
  },
  "class 父类初始化方法初始化继承属性": {
    "prefix": ["super init -class"],
    "body": ["super().__init__()", ""],
    "description": ["class 父类初始化方法初始化继承属性"]
  },
  "class初始化": {
    "prefix": ["def init slf -class"],
    "body": ["def __init__(self, *args, **kwds) -> None:", "    super().__init__(*args, **kwds)"],
    "description": ["class初始化"]
  },

  "class类self": {
    "prefix": ["slf -class"],
    "body": ["self$0"],
    "description": ["class类self"]
  },
  "创建class - def函数": {
    "prefix": ["new def slf -class", "def slf -class"],
    "body": ["def ${1:name}(self):", "    return"],
    "description": ["创建class - def函数"]
  },
  "创建def函数": {
    "prefix": ["new def -def", "def new -def"],
    "body": ["def ${1:name}():", "    return"],
    "description": ["创建def函数"]
  },
  "async def 创建异步IO协程函数": {
    "prefix": ["new async def", "asc def"],
    "body": [
      "async def ${1:name}():",
      "    # * ${2:_summary_}",
      "    # await [异步函数] 包装协程任务, 可以获取结果",
      "    # asyncio.to_thread(func) 将同步函数转换为异步函数运行",
      "    # asyncio.create_task(async_task) 建立事件循环, 运行异步任务事件",
      "    # ! 注意: 调用异步协程函数 await 的函数本身也必须是 async def 函数",
      "    # asyncio.run(async_func) 运行事件循环的异步协程函数",
      "    ...",
      "    return",
      ""
    ],
    "description": [
      "async def 创建异步IO协程函数",
      "\n\t-await [异步函数] 包装协程任务, 可以获取结果",
      "\n\t-asyncio.to_thread(func) 将同步函数转换为异步函数运行",
      "\n\t-asyncio.create_task(async_task) 建立事件循环, 运行异步任务事件",
      "\n\t-注意: 调用异步协程函数 await 的函数本身也必须是 async def 函数",
      "\n\t-asyncio.run(async_func) 运行事件循环的异步协程函数"
    ]
  },

  "lambda:匿名函数": {
    "prefix": ["new lambda", "lmda -lambda"],
    "body": ["lambda ${1:e}: ${2:expr表达式}"],
    "description": ["lambda(匿名函数)", "lambda(匿名函数) [参数]: 表达式"]
  },
  "if_main:运行入口 | 调试运行": {
    "prefix": ["if main", "if main ==", "if name == main"],
    "body": ["if __name__ == '__main__':", "    \"\"\"# 运行入口 | 调试运行\"\"\"", "    $0", "    ..."],
    "description": ["if_main:运行入口 | 调试运行"]
  },
  "if_in_main:运行入口 | 调试运行": {
    "prefix": ["if main in", "if name in mp_main"],
    "body": [
      "if __name__ in {'__main__', '__mp_main__'}:",
      "    \"\"\"# 运行入口 | 调试运行 | 多进程[multiprocessing]运行\"\"\"",
      "    $0",
      "    ..."
    ],
    "description": ["if_in_main:运行入口 | 调试运行"]
  }
}
