      "    @property  # * 设置页",
      "    def setting_view(self):",
      "        self._setting_view = ft.Container(",
      "            content=ft.Column(",
      "                controls=[",
      "                    ft.Text(value='🕹️设置', size=48),",
      "                ],",
      "                expand=True,",
      "            ),",
      "            expand=True,",
      "        )",
      "        return self._setting_view",
      "",
      "",
      "class MianApp(ft.Container):",
      "    # * class default args(类变量) | signal(信号)",
      "    def __init__(self, page: ft.Page) -> None:",
      "        # * class input args(参数)",
      "        \"\"\"",
      "        创建 flet 类 Container 容器对象",
      "        继承父类ft.Container容器常用基础参数",
      "            expand=True:拉伸 / width:指定宽度 | height:指定高度",
      "            bgcolor:背景颜色 | border_radius:圆角 | padding:内边距 | margin:外边距",
      "        \"\"\"",
      "        super().__init__(expand=True)  # * 继承父类ft.Container容器对象属性[expand=True:拉伸/width:指定宽度/height:指定高度]",
      "        self.page: ft.Page = page  # * 定义页面对象(self.page: ft.Page 使用类型约束规避 None)",
      "",
      "        # * 页面配置",
      "        self.page_conf",
      "",
      "        # TODO 在 __init__ 中实例化创建需要被调用的控件, 以便后续引用, 顺序: 子控件 -> 父级控件",
      "        # 侧边栏配置",
      "        self.sider = Sider(page=self.page)",
      "",
      "        # * 定义侧边栏按钮数据",
      "        self.sider.home_btn.data = 'home'",
      "        self.sider.chat_btn.data = 'chat'",
      "        self.sider.setting_btn.data = 'setting'",
      "        # * 配置侧边栏事件",
      "        self.sider.home_btn.on_click = lambda e: self.change_view(e)",
      "        self.sider.chat_btn.on_click = lambda e: self.change_view(e)",
      "        self.sider.setting_btn.on_click = lambda e: self.change_view(e)",
      "",
      "        # * 声明 self.current_selected 变量: 用于追踪当前已经被选中的按钮, 同时设置初始值",
      "        self.current_selected: ft.ElevatedButton = self.sider.buttons[2]",
      "",
      "        # * 配置内容视图字典(类型约束: dict[str, Container], 键: (str)视图名称, 值: (Container)视图对象)",
      "        self.views: dict[str, Container] = {",
      "            # * 自定义视图页面",
      "            'home': TabView(page=self.page).home_view,",
      "            'setting': TabView(page=self.page).setting_view,",
      "            # * 内置视图页面",
      "            'loading': self.loading_view,  # 等待加载视图页面",
      "            'error': self.error_view,  # 错误视图页面",
      "        }",
      "",
      "        # TODO 实例化界面内容视图",
      "        self.view = self.content_view()",
      "",
      "        # * --- 设置初始化默认选中项 --- *",
      "        self.change_view(self.current_selected)",
      "",
      "        # ! 添加视图到页面",
      "        self.page.add(",
      "            ft.Row(  # * [水平]布局",
      "                controls=[  # * 添加控件",
      "                    self.sider.view,",
      "                    ft.VerticalDivider(width=1),  # * 垂直分割线",
      "                    self.view,",
      "                ],",
      "                expand=True,  # * 拉伸(若限制 宽度/高度, 则此属性无效)",
      "                spacing=0,  # * 元素间距",
      "            )",
      "        )",
      "",
      "    def content_view(self, Stack_content: bool = False):",
      "        \"\"\"",
      "        界面内容视图封装方式 [二选一]",
      "        @param: Stack_content: bool True: 使用 Stack 容器, False(默认): 使用 Container 容器",
      "        \"\"\"",
      "        if Stack_content:",
      "            # TODO * --- Stack 堆叠预加载界面内容视图 --- *",
      "            # ! Stack 加载内筒需要使用 Container 封装, 并在 Container 封装内部指定对齐方式",
      "            # Stack 会加载所有内容视图, 占用内存",
      "            # * 激活内容视图[Stack.controls内容使用Container封装,并在Container封装内部指定对齐方式]",
      "            self._content_view = ft.Container(",
      "                content=ft.Stack(controls=[*self.views.values()]),",
      "                expand=True,",
      "            )",
      "            # * (可省略)指定默认启动视图",
      "            self.views['loading'].visible = True",
      "        else:",
      "            # TODO * --- Container 替换 controls 懒加载界面内容视图 --- *",
      "            self._content_view = ft.Container(",
      "                content=self.views['loading'],",
      "                expand=True,",
      "            )",
      "        return self._content_view",
      "",
      "    def change_view(self, e: ft.ControlEvent | ft.ElevatedButton):",
      "        \"\"\"",
      "        内容页面视图切换",
      "        通过判断 self.view 的类型[ Stack | Container ], 选择切换视图的方法",
      "        \"\"\"",
      "        if isinstance(self.view, ft.Stack):",
      "            return self.change_Stack_view(e)",
      "        elif isinstance(self.view, ft.Container):",
      "            return self.change_Container_view(e)",
      "        else:",
      "            print(f'self.view类型错误:{type(self.view)}')",
      "            return",
      "",
      "    def change_Stack_view(self, e: ft.ControlEvent | ft.ElevatedButton):",
      "        \"\"\"",
      "        适用于 Stack 堆叠预加载界面内容视图的切换方法",
      "        \"\"\"",
      "        if isinstance(e, ft.ControlEvent):",
      "            # TODO --- 控件触发事件对象 ---",
      "            current_selection: ft.ElevatedButton = e.control  # 获取当前选中按钮,并指定类型",
      "            if self.current_selected and self.current_selected.style:  # 旧的选中按钮",
      "                self.current_selected.style.bgcolor = None  # 重置当前选中按钮的样式",
      "                self.current_selected.style.side = None  # 重置当前选中按钮的边框样式",
      "                self.current_selected.style.text_style = None  # 重置当前选中按钮的文本样式",
      "        else:",
      "            # TODO --- 直接获取控件对象 ---",
      "            current_selection: ft.ElevatedButton = e",
      "        # * --- 切换按钮样式 --- *",
      "        if current_selection and current_selection.style:  # 当前选中按钮",
      "            current_selection.style.bgcolor = ft.Colors.with_opacity(0.5, ft.Colors.LIGHT_BLUE_ACCENT_400)  # 设置当前选中按钮的样式",
      "            current_selection.style.side = ft.BorderSide(width=2, color=ft.Colors.LIGHT_GREEN_ACCENT_400)  # 设置当前选中按钮的边框样式",
      "            current_selection.style.text_style = ft.TextStyle(font_family='BoldFont')  # 设置当前选中按钮的文本样式",
      "        # * --- 切换内容视图 --- *",
      "        # TODO 初始化 self.views 所有视图 visible = False (不显示)",
      "        for view in self.views.values():",
      "            view.visible = False",
      "        if current_selection.data and current_selection.data in self.views.keys():",
      "            # TODO current_selection.data 属性存在 self.views 字典中, 则切换到对应视图, 否则切换到错误视图",
      "            self.views[current_selection.data].visible = True",
      "        else:",
      "            self.views['error'].visible = True",
      "        self.current_selected = current_selection",
      "        self.page.update()",
      "",
      "    def change_Container_view(self, e: ft.ControlEvent | ft.ElevatedButton):",
      "        \"\"\"",
      "        适用于 Container 替换 controls 懒加载界面内容视图的切换方法",
      "        \"\"\"",
      "        if isinstance(e, ft.ControlEvent):",
      "            # TODO 控件触发事件对象",
      "            current_selection: ft.ElevatedButton = e.control  # 获取当前选中按钮,并指定类型",
      "            if self.current_selected and self.current_selected.style:  # 旧的选中按钮",
      "                self.current_selected.style.bgcolor = None  # 重置当前选中按钮的样式",
      "                self.current_selected.style.side = None  # 重置当前选中按钮的边框样式",
      "                self.current_selected.style.text_style = None  # 重置当前选中按钮的文本样式",
      "        else:",
      "            # TODO 直接获取控件对象",
      "            current_selection: ft.ElevatedButton = e",
      "        if current_selection and current_selection.style:  # 当前选中按钮",
      "            current_selection.style.bgcolor = ft.Colors.with_opacity(0.5, ft.Colors.LIGHT_BLUE_ACCENT_400)  # 设置当前选中按钮的样式",
      "            current_selection.style.side = ft.BorderSide(width=2, color=ft.Colors.LIGHT_GREEN_ACCENT_400)  # 设置当前选中按钮的边框样式",
      "            current_selection.style.text_style = ft.TextStyle(font_family='BoldFont')  # 设置当前选中按钮的文本样式",
      "        # * 切换内容视图",
      "        if current_selection.data:",
      "            # TODO current_selection.data 属性存在 self.views 字典中, 则切换到对应视图, 否则切换到错误视图",
      "            self.view.content = self.views[current_selection.data] if current_selection.data in self.views.keys() else self.views['error']",
      "        self.current_selected = current_selection",
      "        self.page.update()",
      "",
      "    @property  # * 页面配置属性",
      "    def page_conf(self):",
      "        \"\"\"",
      "        页面配置",
      "        \"\"\"",
      "        # * 页面标题",
      "        self.page.title = '🤖Flet Counter Example'",
      "        # * 字体 (添加自定义字体)",
      "        self.page.fonts = {",
      "            'LightFont': str(Path(Path(__file__).parent.resolve(), 'Light.ttf')),",
      "            'NormalFont': str(Path(Path(__file__).parent.resolve(), 'Normal.ttf')),",
      "            'BoldFont': str(Path(Path(__file__).parent.resolve(), 'Bold.ttf')),",
      "        }",
      "        # * 定义主题方案 [字体 | 配色]",
      "        self.page.theme = ft.Theme(",
      "            font_family='NormalFont',",
      "            color_scheme=ft.ColorScheme(  # 浅色主题配色方案",
      "                primary=ft.Colors.BLACK,  # 应用界面和组件中的主要颜色[图标/按钮/标签 等界面元素或控件的颜色]",
      "            ),",
      "        )",
      "        self.page.dark_theme = ft.Theme(",
      "            font_family='NormalFont',",
      "            color_scheme=ft.ColorScheme(  # 深色主题配色方案",
      "                primary=ft.Colors.WHITE,  # 应用界面和组件中的主要颜色[图标/按钮/标签 等界面元素或控件的颜色]",
      "            ),",
      "        )",
      "        # * 主题模式 (LIGHT: 浅色, DARK: 深色, SYSTEM[默认]: 系统默认)",
      "        self.page.theme_mode = ft.ThemeMode.SYSTEM",
      "        # * 子控件[垂直]对齐方式 (START[默认]: 顶部, CENTER: 居中, END: 底部, SPACE_BETWEEN: 上下两端对齐, SPACE_AROUND: 上下两端对齐, SPACE_EVENLY: 上下两端对齐)",
      "        self.page.vertical_alignment = ft.MainAxisAlignment.START",
      "        # * 子控件[水平]对齐方式 (START[默认]: 左侧, CENTER: 居中, END: 右侧, STRETCH: 拉伸, BASELINE: 基线对齐)",
      "        self.page.horizontal_alignment = ft.CrossAxisAlignment.START",
      "        # * 页面内边距 (0[默认]: 无内边距, 10: 10px内边距)",
      "        self.page.padding = 0",
      "        # * 页面外边距 (0[默认]: 无外边距, 10: 10px外边距)",
      "        self.page.spacing = 0",
      "        # * 桌面应用/页面 图标 (相对路径)",
      "        # self.page.window.icon = 'assets/icon.png'",
      "        # * 桌面应用/页面 对齐方式(初始位置) [ft.Alignment: 居中:(0,0); 左上:(-1, -1); 右下:(1, 1)]",
      "        self.page.window.alignment = ft.Alignment(0, 0)",
      "        # * 桌面应用/页面 宽度 | 高度",
      "        self.page.window.width = 1280",
      "        self.page.window.height = 720",
      "        # * 桌面应用/页面 最小宽度 | 最小高度",
      "        self.page.window.min_width = 1280",
      "        self.page.window.min_height = 720",
      "        return self.page",
      "",
      "    @property  # * loading_加载中页面",
      "    def loading_view(self):",
      "        \"\"\"",
      "        loading: 加载中页面",
      "        \"\"\"",
      "        self._loading_view = ft.Container(",
      "            content=ft.Column(",
      "                controls=[",
      "                    ft.Text(value='loading...', size=32, color=ft.Colors.GREY_500),",
      "                ],",
      "                expand=True,",
      "                alignment=ft.MainAxisAlignment.CENTER,",
      "                horizontal_alignment=ft.CrossAxisAlignment.CENTER,",
      "            ),",
      "            expand=True,",
      "            alignment=ft.alignment.center,",
      "        )",
      "        return self._loading_view",
      "",
      "    @property  # * 404_错误页面",
      "    def error_view(self):",
      "        \"\"\"",
      "        404: 错误页面",
      "        \"\"\"",
      "        self._error_view = ft.Container(",
      "            content=ft.Column(",
      "                controls=[",
      "                    ft.Text(value='code: 404', size=64),",
      "                    ft.Button(",
      "                        content=ft.Text(value='🔞', size=64, expand=True),",
      "                        width=128,",
      "                        height=128,",
      "                        on_click=lambda e: self.dialog_error(e),",
      "                    ),",
      "                ],",
      "                expand=True,",
      "                alignment=ft.MainAxisAlignment.CENTER,",
      "                horizontal_alignment=ft.CrossAxisAlignment.CENTER,",
      "            ),",
      "            expand=True,",
      "            alignment=ft.alignment.center,",
      "        )",
      "        return self._error_view",
      "",
      "    def dialog_error(self, e: ft.ControlEvent):",
      "        \"\"\"",
      "        AlertDialog 界面模版",
      "        模拟点击后弹窗等待事件处理",
      "        :param e: ft.ControlEvent 事件对象",
      "        \"\"\"",
      "        e_control: ft.ElevatedButton = e.control  # 获取当前点击的按钮",
      "        e_control.disabled = True  # 禁用按钮",
      "        e_control.update()  # 更新按钮",
      "        dlg = ft.AlertDialog(",
      "            modal=True,  # 是否可以通过单击外部区域关闭弹窗[默认:False 可通过单击外部的区域关闭对话框](modal 属性无法改变)",
      "            title=ft.Text(value='☣️', size=64),  # 弹窗标题",
      "            content=ft.Row(  # * 弹窗内容",
      "                controls=[",
      "                    ft.ProgressRing(),  # 环形循环旋转进度指示器",
      "                    ft.Text(value='正在分析错误...', size=32),",
      "                ],",
      "            ),",
      "            alignment=ft.alignment.center,  # 弹窗对齐方式",
      "            actions=[],  # 弹窗底部容器",
      "            actions_alignment=ft.MainAxisAlignment.END,  # 弹窗底部容器水平布局",
      "            on_dismiss=lambda e: print(f'弹窗关闭事件:{e}'),  # 关闭对话框时触发事件",
      "        )",
      "        self.page.open(dlg)",
      "",
      "        # * --- 模拟处理耗时... --- *",
      "        import asyncio  # 异步IO实现更高的并发性",
      "",
      "        asyncio.run(asyncio.sleep(1))",
      "        dlg.content = ft.Row(  # * 弹窗内容",
      "            controls=[",
      "                ft.ProgressRing(),  # 环形循环旋转进度指示器",
      "                ft.Text(value='努力修复中...', size=32),",
      "            ],",
      "        )",
      "        dlg.update()",
      "        asyncio.run(asyncio.sleep(1))",
      "",
      "        # * 更新弹窗内容并允许关闭",
      "        dlg.title = ft.Text(value='🚧', size=64)",
      "        dlg.content = ft.Text(value='⛔施工中...', size=32)",
      "        dlg.actions.append(ft.ElevatedButton(text='确定', on_click=lambda e: self.page.close(dlg)))",
      "        dlg.update()",
      "        e_control.disabled = False  # 恢复按钮可用",
      "        e_control.update()  # 更新按钮",
      "",
      "",
      "if __name__ == '__main__':",
      "    \"\"\"",
