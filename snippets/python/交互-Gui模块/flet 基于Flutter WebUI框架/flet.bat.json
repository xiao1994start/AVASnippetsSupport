{
  "pip|uv flet 基于 Flutter 的WebUI框架": {
    "prefix": ["pip flet", "uv flet"],
    "body": [
      "ECHO.",
      "ECHO * flet 基于 Flutter 的WebUI框架 *",
      "pip install \"flet[all]\" \"setuptools\" \"pyinstaller\" --upgrade -i https://mirrors.aliyun.com/pypi/simple/",
      "uv add \"flet[all]\" \"setuptools\" \"pyinstaller\" --upgrade --index https://mirrors.aliyun.com/pypi/simple/",
      "@REM * 必备 - https://github.com/flet-dev/flet/releases [最新版] 或 https://sourceforge.net/projects/flet.mirror/files/ [最新版]",
      "@REM * 手动下载 flet-windows.zip 解压后放在 %USERPROFILE%\\.flet\\client\\flet-desktop-full-[版本号]\\flet\\flet.exe [注意目录结构]",
      "@REM ; 写入运行脚本",
      "( ECHO @ECHO OFF",
      "ECHO setlocal EnableDelayedExpansion",
      "ECHO set \"SYSTEM_PATH=%%CommonProgramFiles(x86)%%\\Intel\\Shared Libraries\\bin32;%%CommonProgramFiles(x86)%%\\Intel\\Shared Libraries\\bin;%%SystemRoot%%;%%SystemRoot%%\\system32;%%SystemRoot%%\\System32\\Wbem;%%%SystemRoot%%%\\System32\\WindowsPowerShell\\v1.0\\;%%SystemRoot%%\\System32\\OpenSSH\\\"",
      "ECHO @REM * 添加临时系统环境变量",
      "ECHO set \"PYTHON_PATH=.\\python\\;.\\python\\Scripts\\;\"",
      "ECHO set \"PATH=%%PYTHON_PATH%%;%%SYSTEM_PATH%%;\"",
      "ECHO ECHO python 版本号",
      "ECHO call python --version",
      "ECHO ECHO pip 版本号",
      "ECHO call pip --version",
      "ECHO @REM * 激活Python环境",
      "ECHO call \".\\.venv\\Scripts\\activate\"",
      "ECHO @REM * 运行Python文件",
      "ECHO call flet run \".\\main.py\"",
      "ECHO endlocal )>\"%~dp0_felt_run.cmd\"",
      "ECHO - Creating a new Flet app",
      "@REM flet create",
      "@REM uv run flet create",
      "",
      "",
      "ECHO 智能主题模式检测库",
      "pip install \"darkdetect\" --upgrade -i https://mirrors.aliyun.com/pypi/simple/",
      "uv add \"darkdetect\" --upgrade --index https://mirrors.aliyun.com/pypi/simple/",
      ""
    ],
    "description": ["flet 基于 Flutter 的WebUI框架"]
  }
}
