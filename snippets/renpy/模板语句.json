  "快速构建archive.rpa单文件打包": {
    "prefix": ["init python build archive", "init python build one"],
    "body": [
      "init python:",
      "    # *python语句块*",
      "    # !构建文件路径(建议不要使用):build.destination",
      "    # TODO:定义归档文件",
      "    # *定义 所有文件 | 无标签文件 放入`archive`归档",
      "    build.archive(\"archive\", \"all\")",
      "    # !将文件分类为“无”以将其从构建的分发中 None",
      "    build.classify('**~', None)",
      "    build.classify('**.bak', None)",
      "    build.classify('**/.**', None)",
      "    build.classify('**/#**', None)",
      "    build.classify('**/**.db', None)",
      "    build.classify('**/thumbs.db', None)",
      "    build.classify('**.psd', None)",
      "    build.classify('**.zip', None)",
      "    build.classify('**.xls', None)",
      "    build.classify('**.xlsm', None)",
      "    build.classify('**.rpy', None)",
      "    build.classify('**.rpym', None)",
      "    build.classify('**.py', None)",
      "    build.classify('**.bat', None)",
      "    build.classify('**.csv', None)",
      "    build.classify('**/desktop.ini', None)",
      "    build.classify('game/script/dev.rpyc', None)",
      "    # TODO:视频归档`archive`",
      "    build.classify(\"game/**.py\", \"archive\")",
      "    build.classify(\"game/**.pyo\", \"archive\")",
      "    build.classify(\"game/**.pyx\", \"archive\")",
      "    build.classify(\"game/**.rpymc\", \"archive\") ",
      "    build.classify(\"game/**.rpyb\", \"archive\")",
      "    build.classify(\"game/**.rpyc\", \"archive\")",
      "    build.classify(\"game/**.webm\", \"archive\")",
      "    build.classify(\"game/**.avi\", \"archive\")",
      "    build.classify(\"game/**.wav\", \"archive\")",
      "    build.classify(\"game/**.mp4\", \"archive\")",
      "    build.classify(\"game/**.rpy\", \"archive\")",
      "    build.classify(\"game/**.rpyc\", \"archive\")",
      "    build.classify(\"game/**.tab\", \"archive\")",
      "    build.classify(\"game/**.webp\", \"archive\")",
      "    build.classify(\"game/**.jpg\", \"archive\")",
      "    build.classify(\"game/**.jpeg\", \"archive\")",
      "    build.classify(\"game/**.png\", \"archive\")",
      "    build.classify(\"game/**.ogg\", \"archive\")",
      "    build.classify(\"game/**.mp3\", \"archive\")",
      "    build.classify(\"game/**.ttf\", \"archive\")",
      "    build.classify(\"game/**.otf\", \"archive\")",
      "    build.classify(\"game/**.opus\", \"archive\")",
      "",
      "    build.documentation('*.html')",
      "    build.documentation('*.txt')",
      ""
    ],
    "description": ["快速构建archive.rpa单文件打包"]
  },
