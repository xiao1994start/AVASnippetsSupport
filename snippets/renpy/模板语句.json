  "构建rpa归档文件": {
    "prefix": ["init python build"],
    "body": [
      "init python:",
      "    # *python语句块*",
      "    # !构建文件路径(建议不要使用):build.destination",
      "    build.archive(\"scripts\", \"all\")",
      "    build.archive(\"images\", \"all\")",
      "    build.archive(\"audio\", \"all\")",
      "    build.archive(\"video\", \"all\")",
      "    build.archive(\"fonts\", \"all\")",
      "",
